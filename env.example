# 投资笔记服务端数据库配置
DB_HOST=120.46.220.39
DB_PORT=5432
DB_USER=invest
DB_PASSWORD=your_password
DB_NAME=invest
AUTH_SECRET=change_this_to_a_long_random_string

# 可选：统计
NEXT_PUBLIC_GA_ID=

# 基金持仓 OCR 文本解析 LLM 代理（OpenAI 兼容接口，可选；未配置则扫描识别功能不可用）
